<configuration>

    <property name="LOG_PATTERN"
              value="%d{HH:mm:ss.SSS} [%thread] %highlight(%-5level) [traceId=%X{traceId}] [uri=%X{uri}] %logger{36} - %msg%n"/>

    <!-- 콘솔 -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- 패키지별 로그 레벨 -->
    <logger name="org.jnjeaaaat.openmarket" level="DEBUG"/>

    <!-- 루트 -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>